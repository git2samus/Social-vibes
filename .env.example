# ---------------------------------------------------------------------------
# Rate-limiting — unfollow
# ---------------------------------------------------------------------------
# Seconds to wait between individual unfollows (random value in [min, max]).
UNFOLLOW_MIN_DELAY=20
UNFOLLOW_MAX_DELAY=45

# Pause after this many unfollows in a row.
UNFOLLOW_BATCH_SIZE=10

# Duration of that pause (seconds).
UNFOLLOW_BATCH_PAUSE=300

# ---------------------------------------------------------------------------
# Rate-limiting — profile enrichment
# ---------------------------------------------------------------------------
# Seconds to wait between profile page loads when running --enrich.
ENRICH_MIN_DELAY=3
ENRICH_MAX_DELAY=7
